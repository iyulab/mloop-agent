<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Add sources explicitly without <clear /> to preserve user-level config -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="devexpress" value="https://nuget.devexpress.com/nCBEVrm8ivo1sAqggAaV6tTEr8L5oIQceDb6hwmf2t7mMn8T3C/api/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- Default: use primary source for unmapped packages -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="devexpress">
      <package pattern="DevExpress*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
